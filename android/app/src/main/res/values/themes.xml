<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Fitivy" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Main Brand Colors -->
        <item name="colorPrimary">@color/fitivy_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/fitivy_primary_light</item>
        <item name="colorOnPrimaryContainer">@color/fitivy_primary</item>

        <item name="colorSecondary">@color/fitivy_primary</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Background & Surface -->
        <item name="android:windowBackground">@color/bg_main</item>
        <item name="android:statusBarColor">@color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Components Style -->
        <item name="materialButtonStyle">@style/Widget.Fitivy.Button</item>
        <item name="bottomNavigationStyle">@style/Widget.Fitivy.BottomNavigationView</item>

        <!-- Global Font -->
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Rounded Button Style -->
    <style name="Widget.Fitivy.Button" parent="Widget.Material3.Button">
        <item name="shapeAppearance">@style/ShapeAppearance.Fitivy.Button</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="ShapeAppearance.Fitivy.Button" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerSize">24dp</item>
    </style>

    <!-- Bottom Navigation Style -->
    <style name="Widget.Fitivy.BottomNavigationView" parent="Widget.Material3.BottomNavigationView">
        <item name="itemIconTint">@color/bottom_nav_selector</item>
        <item name="itemTextColor">@color/bottom_nav_selector</item>
        <item name="itemRippleColor">@color/fitivy_primary_light</item>
        <item name="backgroundTint">@color/white</item>
    </style>
</resources>
